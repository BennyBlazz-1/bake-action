{
  "name": "bake-action-demo",
  "version": "1.0.0",
  "description": "Aplicación demo en Node y Express para CI/CD con docker/bake-action",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "test": "jest --runInBand --coverage"
  },
  "keywords": [
    "node",
    "express",
    "docker",
    "bake",
    "github-actions",
    "ci-cd"
  ],
  "author": "Tu nombre",
  "license": "MIT",
  "dependencies": {
    "express": "^5.1.0"
  },
  "devDependencies": {
    "jest": "^30.2.0",
    "supertest": "^7.1.4"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "src/**/*.js"
    ],
    "coverageDirectory": "coverage"
  }
}